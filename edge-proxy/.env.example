NODE_ENV=development
PROXY_PORT=8080
PROXY_HOST=0.0.0.0

# Redis (L2 cache + rate limiting)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL (metrics persistence)
# Option A: Neon / cloud connection string (recommended)
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Option B: local PostgreSQL (used when DATABASE_URL is unset)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=edgeflow
PG_PASSWORD=edgeflow
PG_DATABASE=edgeflow
PG_SSL=false

# Load balancer
LB_ALGORITHM=round-robin

# Rate limiting
RATE_LIMIT_ALGORITHM=token-bucket
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Cache
L1_MAX_ENTRIES=500
L1_TTL_MS=60000
L2_TTL_MS=120000
CACHE_ENABLED=true

# Retry / failover
MAX_RETRIES=3
RETRY_BACKOFF_MS=100
REQUEST_TIMEOUT_MS=8000

# Health checks
HEALTH_CHECK_INTERVAL_MS=5000

# Compression
COMPRESSION_ENABLED=true
COMPRESSION_MIN_BYTES=1024

# Logging
LOG_LEVEL=info
